# PostgreSQL — Cloud SQL connection string
# Local dev:    postgresql://postgres:password@localhost:5432/propmatch
# Cloud Run:    postgresql://postgres:password@/propmatch?host=/cloudsql/propmatch-mobile:asia-south1:propmatch
DATABASE_URL=postgresql://postgres:password@localhost:5432/propmatch

# Firebase Admin — path to service account JSON (local dev only)
# On Cloud Run / Cloud Functions this is set automatically via workload identity
GOOGLE_APPLICATION_CREDENTIALS=/path/to/serviceAccountKey.json

# Firebase project ID
FIREBASE_PROJECT_ID=propmatch-mobile

PORT=8080
